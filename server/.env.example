# Daraja API Credentials (Get from https://developer.safaricom.co.ke)
CONSUMER_KEY=your_consumer_key_here
CONSUMER_SECRET=your_consumer_secret_here
PASSKEY=your_passkey_here
SHORTCODE=174379
INITIATOR_PASSWORD=your_initiator_password_here

# M-Pesa URLs
MPESA_ENDPOINT=https://sandbox.safaricom.co.ke
# For production: https://api.safaricom.co.ke

# Your website URLs
CALLBACK_URL=http://localhost:5000/api/payment/callback
# If Daraja sandbox cannot reach localhost, expose the server with ngrok and update this URL.
# List allowed frontend origins separated by commas, for example:
# FRONTEND_URL=http://localhost:3000,https://blue-rangers.vercel.app
FRONTEND_URL=http://localhost:3000

# Server
PORT=5000
NODE_ENV=development
