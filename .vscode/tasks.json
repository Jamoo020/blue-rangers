			"label": "Verify Strapi API",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-Command",
				"try { $r = Invoke-WebRequest -Uri 'http://localhost:1337/api/news?populate=*' -UseBasicParsing -ErrorAction Stop; $r.StatusCode; $r.Content | ConvertFrom-Json | Select-Object -Property data } catch { $_.Exception.Response.StatusCode }"
			],
			"isBackground": false,
			"group": "test"
		},
